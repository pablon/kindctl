#!/usr/bin/env bash
# shellcheck disable=SC2155,SC2016,SC2086
##########################################################
# Description:  kind wrapper tool for local kuberetes cluster management
# Author:       https://github.com/pablon
#
# Usage:
# kindctl <command> [name] [-d]
#   new [name] [-d]  create a cluster (use -d for dry-run)
#   get              get kubeconfig for cluster
#   del [name]       delete an existing cluster
#   -h               this help
#
# Dependencies: curl, fzf, jq, docker, helm, kind, kubectl
##########################################################
set -euo pipefail

# preferred location to store kubeconfig files
# each cluster uses a separate kubeconfig file to make it easier to manage
# works best for kubie (https://github.com/kubie-org/kubie)
KUBECONFIG_DIR="${HOME}/.kube/configs"

CYAN="\033[1;96m"
GREEN="\033[1;92m"
MAGENTA="\033[1;95m"
RED="\033[1;31m"
YELLOW="\033[1;93m"
NC="\033[0m"

divider() {
  [[ "${COLUMNS}" ]] || local COLUMNS=80
  echo -e "${CYAN}$(eval "printf '─%.0s' {1..$COLUMNS}")${NC}"
}

show_help() {
  cat <<HELP
$(basename -- "$0"): kind wrapper tool for local kuberetes cluster management

Usage: $(basename -- "$0") <command> [name] [-d]
  new [name] [-d]  create a cluster (use -d for dry-run)
  get              get kubeconfig for cluster
  del [name]       delete an existing cluster
  -h               this help

HELP
  exit 0
}

# Required dependencies
deps=(curl fzf jq docker helm kind kubectl)
deps_missing=()
for dep in "${deps[@]}"; do
  if (! command -v "${dep}" &>/dev/null); then
    deps_missing+=("$dep")
  fi
  unset dep
done
if [ "${#deps_missing[@]}" -gt "0" ]; then
  echo -e "${YELLOW} ⚠️ Found [${#deps_missing[@]}] missing dependencies, please install: ${MAGENTA}${deps_missing[*]}${NC}\n"
  exit 1
fi

gather_info() {
  divider
  get_cluster_name() {
    read -rp " ☸️ Enter new cluster name (alphanumeric and dashes only): " KIND_CLUSTER_NAME
    while [[ ! "${KIND_CLUSTER_NAME}" =~ ^[a-z0-9-]+$ ]] || [ -z "${KIND_CLUSTER_NAME}" ]; do
      if [ -n "${KIND_CLUSTER_NAME}" ]; then
        echo -e "${RED}Error: Cluster name must contain only lowercase letters, numbers, and dashes${NC}"
      fi
      read -rp " ☸️ Enter new cluster name (alphanumeric and dashes only): " KIND_CLUSTER_NAME
    done
    export KIND_CLUSTER_NAME="${KIND_CLUSTER_NAME}"
  }
  get_node_image_tags() {
    local MAX_RESULTS=20
    export KIND_NODE_TAG="$(curl -fsSL \
      "https://hub.docker.com/v2/repositories/kindest/node/tags?page_size=10&ordering=last_updated" |
      jq -r '.results[].name | select(test("^v?[0-9]+\\.[0-9]+\\.[0-9]+$"))' |
      head -n $MAX_RESULTS | sort -nr | fzf --layout reverse --height 40% --ghost="Select kubernetes version for cluster [${KIND_CLUSTER_NAME}]")"

    [ -z "${KIND_NODE_TAG}" ] && exit 0
    export KIND_NODE_VERSION="kindest/node:${KIND_NODE_TAG}"
  }
  get_cluster_nodes() {
    local DEFAULT_NODES="1"
    local MAX_NODES="3"
    read -rp " 🚜 Enter number of nodes (1-${MAX_NODES}), Hit enter for default [${DEFAULT_NODES}]: " KIND_CLUSTER_NODES
    [[ ! ${KIND_CLUSTER_NODES} ]] && KIND_CLUSTER_NODES="1"
    if ! [[ "${KIND_CLUSTER_NODES}" =~ ^[0-9]+$ ]] || [ "${KIND_CLUSTER_NODES}" -eq "0" ] || [ "${KIND_CLUSTER_NODES}" -gt "${MAX_NODES}" ]; then
      echo -e "${RED}Error: Maximum number of nodes is ${MAX_NODES}, please try again${NC}"
      get_cluster_nodes
    fi
    export KIND_CLUSTER_NODES="${KIND_CLUSTER_NODES}"
    if [ "${KIND_CLUSTER_NODES}" -gt "1" ]; then
      export KIND_WORKER_NODES="$((KIND_CLUSTER_NODES - DEFAULT_NODES))"
    fi
  }
  [ -z "${1}" ] && get_cluster_name
  get_node_image_tags
  get_cluster_nodes
}

create_cluster() {
  local KIND_CLUSTER_NAME="${1}"
  gather_info "${1}"
  divider
  mkdir -p "${KUBECONFIG_DIR}"
  local KIND_KUBECONFIG="${KUBECONFIG_DIR}/kind-${KIND_CLUSTER_NAME}.yaml"
  local KIND_CONFIG="$(mktemp -t "kind-config-${KIND_CLUSTER_NAME}").yaml"

  echo -e " ${CYAN}New cluster: ${GREEN}${KIND_CLUSTER_NAME}${NC}
     ${CYAN}Version:${NC} ${KIND_NODE_VERSION#*v}
       ${CYAN}Nodes:${NC} ${KIND_CLUSTER_NODES}
  ${CYAN}KUBECONFIG:${NC} ${KIND_KUBECONFIG}"

  if [ "${MODE}" != "dryrun" ]; then
    echo
    read -rp " ❓ Proceed with cluster creation? [Y/n]: " START
    case "${START}" in
    N | n)
      echo
      exit 0
      ;;
    *)
      true
      ;;
    esac
  fi

  echo
  echo -e "${GREEN} ⚙️ Adding control-plane to kind-config..${NC}"
  cat <<EOF >"${KIND_CONFIG}"
apiVersion: kind.x-k8s.io/v1alpha4
kind: Cluster
name: ${KIND_CLUSTER_NAME}
networking:
  apiServerPort: 6443
  # ipFamily: ipv4
  # apiServerAddress: 127.0.0.1
nodes:
  # control-plane
  - role: control-plane
    kubeadmConfigPatches:
      - |
        kind: InitConfiguration
        nodeRegistration:
          kubeletExtraArgs:
            node-labels: "ingress-ready=true"
    extraPortMappings:
      - containerPort: 80
        hostPort: 80
        protocol: TCP
      - containerPort: 443
        hostPort: 443
        protocol: TCP
EOF

  if [ "${KIND_WORKER_NODES:-}" ]; then
    for i in $(seq 1 "${KIND_WORKER_NODES}"); do
      echo -e "${GREEN} ⚙️ Adding worker #${i} to kind-config..${NC}"
      echo -e "  # worker #${i}\n  - role: worker" >>"${KIND_CONFIG}"
    done
  fi

  CREATE_COMMAND="kind create cluster --name ${KIND_CLUSTER_NAME} --image ${KIND_NODE_VERSION} --kubeconfig ${KIND_KUBECONFIG} --config ${KIND_CONFIG}"

  if [ "${MODE}" == "dryrun" ]; then
    echo
    echo -e "${RED} 🛟 DRY-RUN -- kind-config:\n${YELLOW}$(cat "${KIND_CONFIG}")${NC}"
    echo
    echo -e "${RED} 🛟 DRY-RUN -- create cluster command:\n${GREEN}${CREATE_COMMAND}${NC}"
  else
    echo
    local cmd_args=(create cluster --name "${KIND_CLUSTER_NAME}" --image "${KIND_NODE_VERSION}" --kubeconfig "${KIND_KUBECONFIG}" --config "${KIND_CONFIG}")
    kind "${cmd_args[@]}"
    echo -e "${CYAN}"
    kubectl cluster-info --context "kind-${KIND_CLUSTER_NAME}" --kubeconfig "${KIND_KUBECONFIG}"
    echo -e "${NC}"
  fi

  # cleanup
  rm -f "${KIND_CONFIG}"

  # do the rest
  install_metallb
  install_ingress_nginx
  install_cert_manager
  install_caretta
  show_cluster_objects
  show_final_help
}

get_kind_network_ip_range() {
  local subnet
  subnet=$(docker network inspect kind -f '{{range .IPAM.Config}}{{.Subnet}}{{end}}' 2>/dev/null | grep -v ":" | head -n1)
  if [[ -z "$subnet" ]]; then
    # Default fallback if network doesn't exist yet
    echo "172.18.255.100-172.18.255.200"
  else
    local base=$(echo "$subnet" | cut -d. -f1-2)
    echo "${base}.255.100-${base}.255.200"
  fi
}

install_metallb() {
  if [ "${MODE}" == "dryrun" ]; then
    echo -e "${RED} 🛟 DRY-RUN -- metallb would be installed${NC}"
  else
    export KUBECONFIG="${KIND_KUBECONFIG}"
    local METALLB_IP_RANGE="$(get_kind_network_ip_range)"
    local METALLB_MANIFEST="https://raw.githubusercontent.com/metallb/metallb/refs/heads/main/config/manifests/metallb-native.yaml"
    divider
    echo -e "${GREEN} 📦 Installing metallb load-balancer:${NC}"
    kubectl apply -f "${METALLB_MANIFEST}"
    echo -e "${GREEN} ⌛️ Waiting for pods to be ready..${NC}"
    kubectl wait \
      --namespace metallb-system \
      --for=condition=ready pod \
      --selector=app=metallb \
      --timeout=120s
    cat <<EOF | kubectl apply -f -
apiVersion: metallb.io/v1beta1
kind: IPAddressPool
metadata:
  name: kind-pool
  namespace: metallb-system
spec:
  addresses:
  - ${METALLB_IP_RANGE}
---
apiVersion: metallb.io/v1beta1
kind: L2Advertisement
metadata:
  name: l2-advert
  namespace: metallb-system
spec:
  ipAddressPools:
  - kind-pool
EOF
    kubectl -n metallb-system get ipaddresspools,l2advertisements
  fi
}

# https://github.com/kubernetes/ingress-nginx/tree/main/charts/ingress-nginx
install_ingress_nginx() {
  if [ "${MODE}" == "dryrun" ]; then
    echo -e "${RED} 🛟 DRY-RUN -- ingress-nginx would be installed${NC}"
  else
    export KUBECONFIG="${KIND_KUBECONFIG}"
    local HELM_REPO="ingress-nginx"
    local HELM_REPO_URI="https://kubernetes.github.io/ingress-nginx"
    divider
    echo -e "${GREEN} 📦 Installing ingress-nginx controller:${NC}"
    (helm repo list | grep "^${HELM_REPO}" &>/dev/null) || helm repo add "${HELM_REPO}" "${HELM_REPO_URI}" &>/dev/null
    # install with control-plane taint toleration
    helm upgrade --install ingress-nginx ingress-nginx/ingress-nginx \
      --namespace ingress-nginx \
      --create-namespace \
      --set controller.kind=Deployment \
      --set controller.replicaCount=1 \
      --set controller.ingressClassResource.name=nginx \
      --set controller.ingressClass=nginx \
      --set controller.hostPort.enabled=true \
      --set controller.service.type=LoadBalancer \
      --set-string controller.nodeSelector.ingress-ready="true" \
      --set-string controller.tolerations[0].key="node-role.kubernetes.io/control-plane" \
      --set-string controller.tolerations[0].operator="Exists" \
      --set-string controller.tolerations[0].effect="NoSchedule" \
      --set-string controller.tolerations[1].key="node-role.kubernetes.io/master" \
      --set-string controller.tolerations[1].operator="Exists" \
      --set-string controller.tolerations[1].effect="NoSchedule"
    echo -e "${GREEN} ⌛️ Waiting for pods to be ready..${NC}"
    kubectl wait \
      --namespace ingress-nginx \
      --for=condition=ready pod \
      --selector=app.kubernetes.io/name=ingress-nginx \
      --timeout=120s
    kubectl -n ingress-nginx get all
  fi
}

# https://github.com/cert-manager/cert-manager/tree/master/deploy/charts/cert-manager
install_cert_manager() {
  if [ "${MODE}" == "dryrun" ]; then
    echo -e "${RED} 🛟 DRY-RUN -- cert-manager would be installed${NC}"
  else
    create_cert_manager_cluster_issuer() {
      if [ "${MODE}" != "dryrun" ]; then
        export KUBECONFIG="${KIND_KUBECONFIG}"
        cat <<EOF | kubectl apply -f -
apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: local-selfsigned-bootstrap
spec:
  selfSigned: {}
---
apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: local-root-ca
  namespace: cert-manager
spec:
  isCA: true
  commonName: local-root-ca
  secretName: local-root-ca-secret
  privateKey:
    algorithm: ECDSA
    size: 256
  issuerRef:
    name: local-selfsigned-bootstrap
    kind: ClusterIssuer
    group: cert-manager.io
---
apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: local-ca
spec:
  ca:
    secretName: local-root-ca-secret
EOF
        kubectl wait --for=condition=ready clusterissuers/local-ca --timeout=60s
        kubectl get clusterissuers -o wide
        kubectl get certificate -n cert-manager
        kubectl get secret -n cert-manager local-root-ca-secret
      fi
    }
    export KUBECONFIG="${KIND_KUBECONFIG}"
    local HELM_REPO="jetstack"
    local HELM_REPO_URI="https://charts.jetstack.io"
    divider
    echo -e "${GREEN} 📦 Installing cert-manager for TLS management:${NC}"
    (helm repo list | grep "^${HELM_REPO}" &>/dev/null) || helm repo add "${HELM_REPO}" "${HELM_REPO_URI}" &>/dev/null
    helm repo up "${HELM_REPO}" &>/dev/null
    helm upgrade --install cert-manager jetstack/cert-manager \
      --namespace cert-manager --create-namespace \
      --set crds.enabled=true \
      --set resources.limits.cpu=250m \
      --set resources.limits.memory=350Mi
    echo -e "${GREEN} ⌛️ Waiting for pods to be ready..${NC}"
    kubectl wait \
      --namespace cert-manager \
      --for=condition=ready pod \
      --selector=app.kubernetes.io/instance=cert-manager \
      --timeout=120s
    # create cluster issuer for self-signed certificates
    create_cert_manager_cluster_issuer
  fi
}

# https://github.com/groundcover-com/caretta/tree/main/chart
install_caretta() {
  if [ "${MODE}" == "dryrun" ]; then
    echo -e "${RED} 🛟 DRY-RUN -- caretta would be installed${NC}"
  else
    local HELM_REPO="caretta"
    local HELM_REPO_URI="https://helm.groundcover.com/"
    divider
    export KUBECONFIG="${KIND_KUBECONFIG}"
    echo -e "${GREEN} 📦 Installing caretta service dependency map tool${NC}"
    (helm repo list | grep "^${HELM_REPO}" &>/dev/null) || helm repo add "${HELM_REPO}" "${HELM_REPO_URI}" &>/dev/null
    helm repo up "${HELM_REPO}" &>/dev/null
    helm upgrade --install caretta \
      --namespace caretta --create-namespace \
      --set resources.limits.cpu=350m \
      --set resources.limits.memory=650Mi \
      --set grafana.grafana\.ini.adminUser=admin \
      --set grafana.grafana\.ini.adminPassword=admin \
      groundcover/caretta
    echo -e "${GREEN} ⌛️ Waiting for pods to be ready..${NC}"
    kubectl wait \
      --namespace caretta \
      --for=condition=ready pod \
      --selector=app.kubernetes.io/instance=caretta \
      --timeout=120s
  fi
}

show_cluster_objects() {
  if [ "${MODE}" != "dryrun" ]; then
    export KUBECONFIG="${KIND_KUBECONFIG}"
    divider
    echo -e "${GREEN} 󰍉 Cluster [${KIND_CLUSTER_NAME}] helm releases:${NC}"
    helm list -A
    echo -e "\n${GREEN} 󰍉 Cluster [${KIND_CLUSTER_NAME}] certificates:${NC}"
    kubectl -n cert-manager get certificates -o wide
    echo -e "\n${GREEN} 󰍉 Cluster [${KIND_CLUSTER_NAME}] resources:${NC}"
    kubectl get deploy,svc -A
    echo -e "\n${GREEN} 󰍉 Cluster [${KIND_CLUSTER_NAME}] nodes:${NC}"
    kubectl get nodes -o wide
    echo
  fi
}

show_final_help() {
  if [ "${MODE}" != "dryrun" ]; then
    export KUBECONFIG="${KIND_KUBECONFIG}"
    divider
    echo -e " ✅ ${STRONG}Cluster [${KIND_CLUSTER_NAME}] is ${GREEN}Ready${NC}"
    echo -e "\n 🪪 ${STRONG}Run ${CYAN}export KUBECONFIG=${KIND_KUBECONFIG}${STRONG} to start working${NC}"
    (type kubie &>/dev/null) && echo -e "\n ☸️ ${STRONG}Run ${CYAN}kubie ctx kind-${KIND_CLUSTER_NAME}${STRONG} to anchor to cluster context${NC}"
    echo -e "\n 🧨 ${STRONG}Run ${CYAN}$(basename -- "$0") del${STRONG} to tear down the cluster${NC}\n"
  fi
}

get_kubeconfig() {
  if [ ! -z "$(kind get clusters)" ]; then
    export THIS_CLUSTER="$(kind get clusters 2>/dev/null | fzf -1 --layout reverse --border --height 25% --prompt='☸️ ' --ghost="select cluster")"
    [ -z "${THIS_CLUSTER}" ] && exit 0
    local KUBECONFIG_RAW="$(kind get kubeconfig --name ${THIS_CLUSTER})"
    local CLUSTER_AUTHORITY_DATA="$(echo "${KUBECONFIG_RAW}" | yq -r '.clusters[0].cluster."certificate-authority-data"')"
    export KUBECONFIG_YAML="$(rg -l "${CLUSTER_AUTHORITY_DATA}" "${KUBECONFIG_DIR}"/*)"
    if [ "${MODE}" == "kubeconfig" ]; then
      divider
      echo -e "${GREEN} 󰄤 KUBECONFIG location for cluster [${THIS_CLUSTER}]${NC}:\n   ${KUBECONFIG_YAML}"
      divider
      if (type bat &>/dev/null); then
        echo "${KUBECONFIG_RAW}" | cut -c1-77 | sed '/data:/ s|$|...|' | bat --style=snip -S --paging never -l yaml -
      else
        kind get kubeconfig --name "${THIS_CLUSTER}" | cut -c1-77 | sed '/data:/ s|$|...|'
      fi
      divider
    fi
  else
    exit 0
  fi
}

delete_cluster() {
  local THIS_CLUSTER="${1}"
  if [[ -z "${THIS_CLUSTER}" ]] || ! kind get clusters 2>/dev/null | grep -q "^${1}\$"; then
    get_kubeconfig
  fi
  if [ "${MODE}" == "delete" ]; then
    if [ ! -z "$(kind get clusters)" ]; then
      echo -e "${YELLOW} ⚠️ WARNING: cluster [${THIS_CLUSTER}] will be deleted !!!${NC}"
      if [ "${MODE}" != "dryrun" ]; then
        read -rp " 🧨 Proceed [y/N]: " DELETE
        case "${DELETE}" in
        Y | y)
          true
          ;;
        *)
          echo
          exit 0
          ;;
        esac
      fi
      kind delete clusters "${THIS_CLUSTER}" &&
        echo -e " 🔥 ${STRONG}Deleted cluster [${THIS_CLUSTER}]${NC}" &&
        rm -f "${KUBECONFIG_YAML}" &&
        echo -e " 🔥 ${STRONG}Deleted ${KUBECONFIG_YAML}${NC}"
    else
      exit 0
    fi
  fi
}

################################################################################
# parse subcommand + arguments

SUBCOMMAND="${1:-}"
shift 2>/dev/null || true

# parse remaining args
CLUSTER_NAME=""
while [[ $# -gt 0 ]]; do
  case "$1" in
  -d | --dry-run)
    MODE=dryrun
    echo -e "${RED} 🛟 DRY-RUN -- simulating all commands${NC}"
    shift
    ;;
  -h | --help)
    show_help
    ;;
  -*)
    echo -e "${RED} ❌ Unknown option: $1${NC}"
    show_help
    ;;
  *)
    CLUSTER_NAME="$1"
    shift
    ;;
  esac
done

# main
case "${SUBCOMMAND}" in
new)
  MODE="${MODE:-install}"
  create_cluster "${CLUSTER_NAME}"
  ;;
get)
  MODE=kubeconfig
  get_kubeconfig
  ;;
del | delete | rm)
  MODE=delete
  delete_cluster "${CLUSTER_NAME}"
  ;;
*) show_help ;;
esac
