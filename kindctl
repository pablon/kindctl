#!/usr/bin/env bash
# shellcheck disable=SC2155,SC2016,SC2086
##########################################################
# Description:  kind wrapper tool for local kuberetes cluster management
# Author:       https://github.com/pablon
# Version:      0.2.0
#
# Usage:
# kindctl <command> [name] [-d]
#   new [name] [-d]  create a cluster (use -d for dry-run)
#   list             list all clusters
#   status [name]    show cluster status
#   del [name]       delete an existing cluster
#   -h               this help
#   -v               show version
#
# Dependencies: curl, fzf, jq, docker, helm, kind, kubectl
##########################################################
set -euo pipefail

readonly KINDCTL_VERSION="0.2.0"

# preferred location to store kubeconfig files
# each cluster uses a separate kubeconfig file to make it easier to manage
# works best for kubie (https://github.com/kubie-org/kubie)
readonly KUBECONFIG_DIR="${HOME}/.kube/configs"

# Global flags
ASSUME_YES=false
ENABLE_PORT_MAPPINGS=false
INSTALL_METALLB=true
INSTALL_INGRESS_NGINX=true
INSTALL_CERT_MANAGER=true
INSTALL_CARETTA=true

CYAN="\033[1;96m"
GREEN="\033[1;92m"
MAGENTA="\033[1;95m"
RED="\033[1;31m"
YELLOW="\033[1;93m"
STRONG="\033[1m"
NC="\033[0m"

# Cleanup handler
cleanup() {
  local exit_code=$?
  if [[ -n "${KIND_CONFIG:-}" ]] && [[ -f "${KIND_CONFIG}" ]]; then
    rm -f "${KIND_CONFIG}"
  fi
  exit "$exit_code"
}
trap cleanup EXIT ERR INT TERM

divider() {
  local COLUMNS=${COLUMNS:-80}
  echo -e "${CYAN}$(eval "printf '─%.0s' {1..$COLUMNS}")${NC}"
}

show_help() {
  cat <<HELP
v${KINDCTL_VERSION}: 
kind wrapper tool for local kubernetes cluster management

Usage: $(basename -- "$0") <command> [name] [options]

Commands:
  new [name]       create a cluster
  list             list all clusters
  status [name]    show cluster status and health
  del [name]       delete an existing cluster

Options:
  -d, --dry-run    preview changes without executing
  -y, --yes        skip confirmation prompts
  -h, --help       show this help
  -v, --version    show version

Examples:
  $(basename -- "$0") new              # Interactive cluster creation
  $(basename -- "$0") new demo -d      # Dry-run for cluster 'demo'
  $(basename -- "$0") list             # List all clusters
  $(basename -- "$0") status demo      # Check cluster 'demo' status
  $(basename -- "$0") del demo -y      # Delete cluster 'demo' without confirmation

HELP
  exit 0
}

# Required dependencies
deps=(curl fzf jq docker helm kind kubectl)
deps_missing=()
for dep in "${deps[@]}"; do
  if (! command -v "${dep}" &>/dev/null); then
    deps_missing+=("$dep")
  fi
  unset dep
done
if [ "${#deps_missing[@]}" -gt "0" ]; then
  echo -e "${YELLOW} ⚠️ Found [${#deps_missing[@]}] missing dependencies, please install: ${MAGENTA}${deps_missing[*]}${NC}\n"
  exit 1
fi

check_existing_port_mappings() {
  # Check if any existing kind cluster has port mappings configured
  local clusters
  clusters="$(kind get clusters 2>/dev/null)"

  if [[ -z "$clusters" ]]; then
    return # No clusters exist
  fi

  # Check each cluster's config for extraPortMappings on ports 80/443
  while IFS= read -r cluster; do
    local config="${KUBECONFIG_DIR}/kind-${cluster}.yaml"
    if [[ -f "$config" ]]; then
      # Get cluster config and check for port mappings
      local cluster_config
      cluster_config=$(kind get kubeconfig --name "$cluster" 2>/dev/null)
      if [[ -n "$cluster_config" ]]; then
        # Check if ports 80 or 443 are in use by docker containers for this cluster
        local containers
        containers=$(docker ps --filter "name=${cluster}-control-plane" --format "{{.Ports}}" 2>/dev/null)
        if echo "$containers" | grep -q "0.0.0.0:80\|0.0.0.0:443"; then
          echo "$cluster"
          return 0 # Found cluster with port mappings
        fi
      fi
    fi
  done <<<"$clusters"

  return 1 # No clusters with port mappings found
}

gather_info() {
  divider
  get_cluster_name() {
    read -rp " ☸️ Enter new cluster name (alphanumeric and dashes only): " KIND_CLUSTER_NAME
    while [[ ! "${KIND_CLUSTER_NAME}" =~ ^[a-z0-9-]+$ ]] || [ -z "${KIND_CLUSTER_NAME}" ]; do
      if [ -n "${KIND_CLUSTER_NAME}" ]; then
        echo -e "${RED}Error: Cluster name must contain only lowercase letters, numbers, and dashes${NC}"
      fi
      read -rp " ☸️ Enter new cluster name (alphanumeric and dashes only): " KIND_CLUSTER_NAME
    done
    export KIND_CLUSTER_NAME="${KIND_CLUSTER_NAME}"
  }

  get_node_image_tags() {
    local MAX_RESULTS=20
    local FALLBACK_VERSION="v1.35.1"

    # Fetch versions from Docker Hub API with error handling
    local api_response
    api_response="$(curl -fsSL \
      "https://hub.docker.com/v2/repositories/kindest/node/tags?page_size=10&ordering=last_updated" 2>&1)" || {
      echo -e "${RED}Error: Failed to fetch Kubernetes versions from Docker Hub API${NC}"
      echo -e "${YELLOW}Using fallback version: ${FALLBACK_VERSION}${NC}"
      export KIND_NODE_TAG="${FALLBACK_VERSION}"
      export KIND_NODE_VERSION="kindest/node:${KIND_NODE_TAG}"
      return 0
    }

    # Parse and display versions
    export KIND_NODE_TAG="$(echo "${api_response}" |
      jq -r '.results[].name | select(test("^v?[0-9]+\\.[0-9]+\\.[0-9]+$"))' 2>/dev/null |
      head -n $MAX_RESULTS | sort -nr | fzf --layout reverse --height 40% --ghost="Select kubernetes version for cluster [${KIND_CLUSTER_NAME}]")"

    # Handle user cancellation (Ctrl+C or ESC)
    if [ -z "${KIND_NODE_TAG}" ]; then
      echo -e "${YELLOW}Selection cancelled${NC}"
      exit 0
    fi

    export KIND_NODE_VERSION="kindest/node:${KIND_NODE_TAG}"
  }
  get_cluster_nodes() {
    local DEFAULT_NODES="1"
    local MAX_NODES="3"
    read -rp " 🚜 Enter number of nodes (1-${MAX_NODES}), Hit enter for default [${DEFAULT_NODES}]: " KIND_CLUSTER_NODES
    [[ ! ${KIND_CLUSTER_NODES} ]] && KIND_CLUSTER_NODES="1"
    if ! [[ "${KIND_CLUSTER_NODES}" =~ ^[0-9]+$ ]] || [ "${KIND_CLUSTER_NODES}" -eq "0" ] || [ "${KIND_CLUSTER_NODES}" -gt "${MAX_NODES}" ]; then
      echo -e "${RED}Error: Maximum number of nodes is ${MAX_NODES}, please try again${NC}"
      get_cluster_nodes
    fi
    export KIND_CLUSTER_NODES="${KIND_CLUSTER_NODES}"
    if [ "${KIND_CLUSTER_NODES}" -gt "1" ]; then
      export KIND_WORKER_NODES="$((KIND_CLUSTER_NODES - DEFAULT_NODES))"
    fi
  }

  ask_port_mappings() {
    # Check if another cluster already has port mappings
    local existing_cluster
    existing_cluster=$(check_existing_port_mappings)

    if [[ -n "$existing_cluster" ]]; then
      echo
      echo -e "${YELLOW} ⚠️  Port mappings (80/443) are already used by cluster: ${MAGENTA}${existing_cluster}${NC}"
      echo -e "${YELLOW}    Only ONE cluster can use ports 80/443 at a time${NC}"
      echo -e "${YELLOW}    Skipping port mapping configuration for this cluster${NC}"
      export ENABLE_PORT_MAPPINGS=false
      return
    fi

    # No conflicts, ask user
    echo
    echo -e "${CYAN} 🔌 Port Mappings Configuration${NC}"
    echo -e "${YELLOW}    Enable extraPortMappings (ports 80/443)?${NC}"
    echo -e "${YELLOW}    This allows direct HTTP/HTTPS access to the cluster${NC}"
    echo -e "${YELLOW}    ⚠️  WARNING: Only ONE cluster can use these ports at a time${NC}"

    if [[ "${ASSUME_YES}" == "true" ]]; then
      echo -e "${GREEN}    Enabled (--yes flag)${NC}"
      export ENABLE_PORT_MAPPINGS=true
    else
      read -rp " ❓ Enable port mappings? [y/N]: " response
      case "${response,,}" in
      y | yes)
        export ENABLE_PORT_MAPPINGS=true
        echo -e "${GREEN}    Port mappings enabled${NC}"
        ;;
      *)
        export ENABLE_PORT_MAPPINGS=false
        echo -e "${YELLOW}    Port mappings disabled${NC}"
        ;;
      esac
    fi
  }

  ask_components() {
    echo
    echo -e "${CYAN} 📦 Components Configuration${NC}"
    echo -e "${YELLOW}    Select which components to install in the cluster:${NC}"

    local components=("metallb" "ingress-nginx" "cert-manager" "caretta")
    local flags=("INSTALL_METALLB" "INSTALL_INGRESS_NGINX" "INSTALL_CERT_MANAGER" "INSTALL_CARETTA")
    local descriptions=(
      "MetalLB load-balancer (required for LoadBalancer services)"
      "ingress-nginx controller (required for Ingress resources)"
      "cert-manager TLS management (self-signed ClusterIssuer included)"
      "Caretta service dependency map tool (includes Grafana)"
    )

    if [[ "${ASSUME_YES}" == "true" ]]; then
      echo -e "${GREEN}    All components enabled (--yes flag)${NC}"
      export INSTALL_METALLB=true
      export INSTALL_INGRESS_NGINX=true
      export INSTALL_CERT_MANAGER=true
      export INSTALL_CARETTA=true
      return
    fi

    for i in "${!components[@]}"; do
      local component="${components[$i]}"
      local flag="${flags[$i]}"
      local description="${descriptions[$i]}"
      echo
      echo -e "${CYAN}    ${component}${NC}: ${description}"
      read -rp " ❓ Install ${component}? [Y/n]: " response
      case "${response,,}" in
      n | no)
        export "${flag}"=false
        echo -e "${YELLOW}    ${component} skipped${NC}"
        ;;
      *)
        export "${flag}"=true
        echo -e "${GREEN}    ${component} will be installed${NC}"
        ;;
      esac
    done
  }
  [ -z "${1}" ] && get_cluster_name
  get_node_image_tags
  get_cluster_nodes
  ask_port_mappings
  ask_components
}

check_port_conflicts() {
  # Only check ports 80/443 if port mappings are enabled
  # Port 6443 is bound to 127.0.0.1 only (no conflicts between clusters)
  if [[ "${ENABLE_PORT_MAPPINGS}" != "true" ]]; then
    return 0 # No port mappings, no conflicts to check
  fi

  local ports=(80 443)
  local conflicts=()

  for port in "${ports[@]}"; do
    local pids
    pids=$(lsof -Pi ":$port" -sTCP:LISTEN -t 2>/dev/null) || true
    if [[ -n "$pids" ]]; then
      local real_conflict=false
      while IFS= read -r pid; do
        [[ -z "$pid" ]] && continue
        local proc_path
        proc_path=$(ps -p "$pid" -o comm= 2>/dev/null) || true
        # On macOS, skip system processes that report listening on ports
        # but don't actually block binding (e.g. com.apple.WebKit.Networking)
        if [[ "$proc_path" != /System/* ]] && [[ "$proc_path" != *com.apple.* ]]; then
          real_conflict=true
          break
        fi
      done <<< "$pids"
      if [[ "$real_conflict" == "true" ]]; then
        conflicts+=("$port")
      fi
    fi
  done

  if [ "${#conflicts[@]}" -gt 0 ]; then
    echo -e "${YELLOW} ⚠️ Warning: The following ports are already in use: ${conflicts[*]}${NC}"
    echo -e "${YELLOW}    This may cause conflicts with the cluster${NC}"

    if [[ "${ASSUME_YES}" == "false" ]]; then
      read -rp " ❓ Continue anyway? [y/N]: " response
      case "${response,,}" in
      y | yes) return 0 ;;
      *)
        echo -e "${RED}Aborting cluster creation${NC}"
        exit 1
        ;;
      esac
    else
      echo -e "${YELLOW}    Continuing due to --yes flag${NC}"
    fi
  fi
}

create_cluster() {
  local KIND_CLUSTER_NAME="${1}"

  gather_info "${1}"

  # Check for port conflicts after gathering info (so we know if port mappings are enabled)
  if [ "${MODE}" != "dryrun" ]; then
    check_port_conflicts
  fi

  divider
  mkdir -p "${KUBECONFIG_DIR}"
  local KIND_KUBECONFIG="${KUBECONFIG_DIR}/kind-${KIND_CLUSTER_NAME}.yaml"
  # Create temp file with proper template to avoid collision
  local KIND_CONFIG
  KIND_CONFIG="$(mktemp -t "kind-config-${KIND_CLUSTER_NAME}.XXXXXX")"
  mv "${KIND_CONFIG}" "${KIND_CONFIG}.yaml"
  KIND_CONFIG="${KIND_CONFIG}.yaml"

  echo -e " ${CYAN}New cluster: ${GREEN}${KIND_CLUSTER_NAME}${NC}
     ${CYAN}Version:${NC} ${KIND_NODE_VERSION#*v}
       ${CYAN}Nodes:${NC} ${KIND_CLUSTER_NODES}
  ${CYAN}KUBECONFIG:${NC} ${KIND_KUBECONFIG}
${CYAN}Port Mappings:${NC} $(if [[ "${ENABLE_PORT_MAPPINGS}" == "true" ]]; then echo -e "${GREEN}Enabled (80/443)${NC}"; else echo -e "${YELLOW}Disabled${NC}"; fi)"

  if [ "${MODE}" != "dryrun" ] && [[ "${ASSUME_YES}" == "false" ]]; then
    echo
    read -rp " ❓ Proceed with cluster creation? [Y/n]: " START
    case "${START}" in
    N | n)
      echo
      exit 0
      ;;
    *)
      true
      ;;
    esac
  fi

  echo
  echo -e "${GREEN} ⚙️ Adding control-plane to kind-config..${NC}"

  # Base control-plane configuration
  cat <<EOF >"${KIND_CONFIG}"
apiVersion: kind.x-k8s.io/v1alpha4
kind: Cluster
name: ${KIND_CLUSTER_NAME}
nodes:
  # control-plane
  - role: control-plane
    kubeadmConfigPatches:
      - |
        kind: InitConfiguration
        nodeRegistration:
          kubeletExtraArgs:
            node-labels: "ingress-ready=true"
EOF

  # Conditionally add extraPortMappings
  if [[ "${ENABLE_PORT_MAPPINGS}" == "true" ]]; then
    cat <<EOF >>"${KIND_CONFIG}"
    extraPortMappings:
      - containerPort: 80
        hostPort: 80
        protocol: TCP
      - containerPort: 443
        hostPort: 443
        protocol: TCP
EOF
  fi

  if [ "${KIND_WORKER_NODES:-}" ]; then
    for i in $(seq 1 "${KIND_WORKER_NODES}"); do
      echo -e "${GREEN} ⚙️ Adding worker #${i} to kind-config..${NC}"
      echo -e "  # worker #${i}\n  - role: worker" >>"${KIND_CONFIG}"
    done
  fi

  CREATE_COMMAND="kind create cluster --name ${KIND_CLUSTER_NAME} --image ${KIND_NODE_VERSION} --kubeconfig ${KIND_KUBECONFIG} --config ${KIND_CONFIG}"

  if [ "${MODE}" == "dryrun" ]; then
    echo
    echo -e "${RED} 🛟 DRY-RUN -- kind-config:\n${YELLOW}$(cat "${KIND_CONFIG}")${NC}"
    echo
    echo -e "${RED} 🛟 DRY-RUN -- create cluster command:\n${GREEN}${CREATE_COMMAND}${NC}"
  else
    echo
    local cmd_args=(create cluster --name "${KIND_CLUSTER_NAME}" --image "${KIND_NODE_VERSION}" --kubeconfig "${KIND_KUBECONFIG}" --config "${KIND_CONFIG}")
    kind "${cmd_args[@]}"
    echo -e "${CYAN}"
    kubectl cluster-info --context "kind-${KIND_CLUSTER_NAME}" --kubeconfig "${KIND_KUBECONFIG}"
    echo -e "${NC}"
  fi

  # cleanup
  rm -f "${KIND_CONFIG}"

  # do the rest
  install_metallb
  install_ingress_nginx
  install_cert_manager
  install_caretta
  show_cluster_objects
  show_final_help
}

get_kind_network_ip_range() {
  local subnet
  subnet=$(docker network inspect kind -f '{{range .IPAM.Config}}{{.Subnet}}{{end}}' 2>/dev/null | grep -v ":" | head -n1)
  if [[ -z "$subnet" ]]; then
    # Default fallback if network doesn't exist yet
    echo "172.18.255.100-172.18.255.200"
  else
    local base=$(echo "$subnet" | cut -d. -f1-2)
    echo "${base}.255.100-${base}.255.200"
  fi
}

install_metallb() {
  if [[ "${INSTALL_METALLB}" != "true" ]]; then
    [ "${MODE}" == "dryrun" ] && echo -e "${RED} 🛟 DRY-RUN -- metallb skipped (disabled by user)${NC}" || echo -e "${YELLOW} ⏭️  Skipping metallb (disabled by user)${NC}"
  elif [ "${MODE}" == "dryrun" ]; then
    echo -e "${RED} 🛟 DRY-RUN -- metallb would be installed${NC}"
  else
    export KUBECONFIG="${KIND_KUBECONFIG}"
    local METALLB_IP_RANGE="$(get_kind_network_ip_range)"
    local METALLB_MANIFEST="https://raw.githubusercontent.com/metallb/metallb/refs/heads/main/config/manifests/metallb-native.yaml"
    divider
    echo -e "${GREEN} 📦 Installing metallb load-balancer:${NC}"
    kubectl apply -f "${METALLB_MANIFEST}"
    echo -e "${GREEN} ⌛️ Waiting for pods to be ready..${NC}"
    kubectl wait \
      --namespace metallb-system \
      --for=condition=ready pod \
      --selector=app=metallb \
      --timeout=120s
    cat <<EOF | kubectl apply -f -
apiVersion: metallb.io/v1beta1
kind: IPAddressPool
metadata:
  name: kind-pool
  namespace: metallb-system
spec:
  addresses:
  - ${METALLB_IP_RANGE}
---
apiVersion: metallb.io/v1beta1
kind: L2Advertisement
metadata:
  name: l2-advert
  namespace: metallb-system
spec:
  ipAddressPools:
  - kind-pool
EOF
    kubectl -n metallb-system get ipaddresspools,l2advertisements
  fi
}

# https://github.com/kubernetes/ingress-nginx/tree/main/charts/ingress-nginx
install_ingress_nginx() {
  if [[ "${INSTALL_INGRESS_NGINX}" != "true" ]]; then
    [ "${MODE}" == "dryrun" ] && echo -e "${RED} 🛟 DRY-RUN -- ingress-nginx skipped (disabled by user)${NC}" || echo -e "${YELLOW} ⏭️  Skipping ingress-nginx (disabled by user)${NC}"
  elif [ "${MODE}" == "dryrun" ]; then
    echo -e "${RED} 🛟 DRY-RUN -- ingress-nginx would be installed${NC}"
  else
    export KUBECONFIG="${KIND_KUBECONFIG}"
    local HELM_REPO="ingress-nginx"
    local HELM_REPO_URI="https://kubernetes.github.io/ingress-nginx"
    divider
    echo -e "${GREEN} 📦 Installing ingress-nginx controller:${NC}"
    (helm repo list | grep "^${HELM_REPO}" &>/dev/null) || helm repo add "${HELM_REPO}" "${HELM_REPO_URI}" &>/dev/null
    # install with control-plane taint toleration
    helm upgrade --install ingress-nginx ingress-nginx/ingress-nginx \
      --namespace ingress-nginx \
      --create-namespace \
      --set controller.kind=Deployment \
      --set controller.replicaCount=1 \
      --set controller.ingressClassResource.name=nginx \
      --set controller.ingressClass=nginx \
      --set controller.hostPort.enabled=true \
      --set controller.service.type=LoadBalancer \
      --set-string controller.nodeSelector.ingress-ready="true" \
      --set-string controller.tolerations[0].key="node-role.kubernetes.io/control-plane" \
      --set-string controller.tolerations[0].operator="Exists" \
      --set-string controller.tolerations[0].effect="NoSchedule" \
      --set-string controller.tolerations[1].key="node-role.kubernetes.io/master" \
      --set-string controller.tolerations[1].operator="Exists" \
      --set-string controller.tolerations[1].effect="NoSchedule"
    echo -e "${GREEN} ⌛️ Waiting for pods to be ready..${NC}"
    kubectl wait \
      --namespace ingress-nginx \
      --for=condition=ready pod \
      --selector=app.kubernetes.io/name=ingress-nginx \
      --timeout=120s
    kubectl -n ingress-nginx get all
  fi
}

# https://github.com/cert-manager/cert-manager/tree/master/deploy/charts/cert-manager
install_cert_manager() {
  if [[ "${INSTALL_CERT_MANAGER}" != "true" ]]; then
    [ "${MODE}" == "dryrun" ] && echo -e "${RED} 🛟 DRY-RUN -- cert-manager skipped (disabled by user)${NC}" || echo -e "${YELLOW} ⏭️  Skipping cert-manager (disabled by user)${NC}"
  elif [ "${MODE}" == "dryrun" ]; then
    echo -e "${RED} 🛟 DRY-RUN -- cert-manager would be installed${NC}"
  else
    create_cert_manager_cluster_issuer() {
      if [ "${MODE}" != "dryrun" ]; then
        export KUBECONFIG="${KIND_KUBECONFIG}"
        cat <<EOF | kubectl apply -f -
apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: local-selfsigned-bootstrap
spec:
  selfSigned: {}
---
apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: local-root-ca
  namespace: cert-manager
spec:
  isCA: true
  commonName: local-root-ca
  secretName: local-root-ca-secret
  privateKey:
    algorithm: ECDSA
    size: 256
  issuerRef:
    name: local-selfsigned-bootstrap
    kind: ClusterIssuer
    group: cert-manager.io
---
apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: local-ca
spec:
  ca:
    secretName: local-root-ca-secret
EOF
        kubectl wait --for=condition=ready clusterissuers/local-ca --timeout=60s
        kubectl get clusterissuers -o wide
        kubectl get certificate -n cert-manager
        kubectl get secret -n cert-manager local-root-ca-secret
      fi
    }
    export KUBECONFIG="${KIND_KUBECONFIG}"
    local HELM_REPO="jetstack"
    local HELM_REPO_URI="https://charts.jetstack.io"
    divider
    echo -e "${GREEN} 📦 Installing cert-manager for TLS management:${NC}"
    (helm repo list | grep "^${HELM_REPO}" &>/dev/null) || helm repo add "${HELM_REPO}" "${HELM_REPO_URI}" &>/dev/null
    helm repo up "${HELM_REPO}" &>/dev/null
    helm upgrade --install cert-manager jetstack/cert-manager \
      --namespace cert-manager --create-namespace \
      --set crds.enabled=true \
      --set resources.limits.cpu=250m \
      --set resources.limits.memory=350Mi
    echo -e "${GREEN} ⌛️ Waiting for pods to be ready..${NC}"
    kubectl wait \
      --namespace cert-manager \
      --for=condition=ready pod \
      --selector=app.kubernetes.io/instance=cert-manager \
      --timeout=120s
    # create cluster issuer for self-signed certificates
    create_cert_manager_cluster_issuer
  fi
}

# https://github.com/groundcover-com/caretta/tree/main/chart
install_caretta() {
  if [[ "${INSTALL_CARETTA}" != "true" ]]; then
    [ "${MODE}" == "dryrun" ] && echo -e "${RED} 🛟 DRY-RUN -- caretta skipped (disabled by user)${NC}" || echo -e "${YELLOW} ⏭️  Skipping caretta (disabled by user)${NC}"
  elif [ "${MODE}" == "dryrun" ]; then
    echo -e "${RED} 🛟 DRY-RUN -- caretta would be installed${NC}"
  else
    local HELM_REPO="caretta"
    local HELM_REPO_URI="https://helm.groundcover.com/"
    divider
    export KUBECONFIG="${KIND_KUBECONFIG}"
    echo -e "${GREEN} 📦 Installing caretta service dependency map tool${NC}"
    (helm repo list | grep "^${HELM_REPO}" &>/dev/null) || helm repo add "${HELM_REPO}" "${HELM_REPO_URI}" &>/dev/null
    helm repo up "${HELM_REPO}" &>/dev/null
    helm upgrade --install caretta \
      --namespace caretta --create-namespace \
      --set resources.limits.cpu=350m \
      --set resources.limits.memory=650Mi \
      --set grafana.grafana\.ini.adminUser=admin \
      --set grafana.grafana\.ini.adminPassword=admin \
      groundcover/caretta
    echo -e "${GREEN} ⌛️ Waiting for pods to be ready..${NC}"
    kubectl wait \
      --namespace caretta \
      --for=condition=ready pod \
      --selector=app.kubernetes.io/instance=caretta \
      --timeout=120s
  fi
}

show_cluster_objects() {
  if [ "${MODE}" != "dryrun" ]; then
    export KUBECONFIG="${KIND_KUBECONFIG}"
    divider
    echo -e "${GREEN} 󰍉 Cluster [${KIND_CLUSTER_NAME}] helm releases:${NC}"
    helm list -A
    echo -e "\n${GREEN} 󰍉 Cluster [${KIND_CLUSTER_NAME}] certificates:${NC}"
    kubectl -n cert-manager get certificates -o wide
    echo -e "\n${GREEN} 󰍉 Cluster [${KIND_CLUSTER_NAME}] resources:${NC}"
    kubectl get deploy,svc -A
    echo -e "\n${GREEN} 󰍉 Cluster [${KIND_CLUSTER_NAME}] nodes:${NC}"
    kubectl get nodes -o wide
    echo
  fi
}

show_final_help() {
  if [ "${MODE}" != "dryrun" ]; then
    export KUBECONFIG="${KIND_KUBECONFIG}"
    divider
    echo -e " ✅ ${STRONG}Cluster [${KIND_CLUSTER_NAME}] is ${GREEN}Ready${NC}"
    echo -e "\n 🪪 ${STRONG}Run ${CYAN}export KUBECONFIG=${KIND_KUBECONFIG}${STRONG} to start working${NC}"
    (type kubie &>/dev/null) && echo -e "\n ☸️ ${STRONG}Run ${CYAN}kubie ctx kind-${KIND_CLUSTER_NAME}${STRONG} to anchor to cluster context${NC}"
    echo -e "\n 🧨 ${STRONG}Run ${CYAN}$(basename -- "$0") del${STRONG} to tear down the cluster${NC}\n"
  fi
}

list_clusters() {
  local clusters
  clusters="$(kind get clusters 2>/dev/null)"

  if [[ -z "$clusters" ]]; then
    echo -e "${YELLOW} ℹ️  No kind clusters found${NC}"
    exit 0
  fi

  divider
  echo -e "${GREEN} ☸️  Kind Clusters:${NC}\n"
  printf "   ${CYAN}%-20s %-15s %-10s %s${NC}\n" "CLUSTER" "VERSION" "NODES" "KUBECONFIG"
  echo

  while IFS= read -r cluster; do
    local config="${KUBECONFIG_DIR}/kind-${cluster}.yaml"
    if [[ -f "$config" ]]; then
      local version
      version=$(kubectl version --kubeconfig="$config" --output=json 2>/dev/null | jq -r '.serverVersion.gitVersion' 2>/dev/null || echo "unknown")
      local node_count
      node_count=$(kubectl get nodes --kubeconfig="$config" --no-headers 2>/dev/null | wc -l | tr -d ' ')
      printf "   ${GREEN}%-20s${NC} ${CYAN}%-15s %-10s${NC} %s\n" "$cluster" "$version" "$node_count nodes" "$config"
    else
      printf "   ${YELLOW}%-20s${NC} ${RED}%-15s %-10s %s${NC}\n" "$cluster" "unknown" "-" "missing"
    fi
  done <<<"$clusters"

  echo
  divider
}

status_cluster() {
  local cluster="${1}"

  # If no cluster specified, use fzf to select
  if [[ -z "$cluster" ]]; then
    local clusters
    clusters="$(kind get clusters 2>/dev/null)"
    if [[ -z "$clusters" ]]; then
      echo -e "${YELLOW} ℹ️  No kind clusters found${NC}"
      exit 0
    fi
    cluster="$(echo "$clusters" | fzf -1 --layout reverse --border --height 25% --prompt='☸️ ' --ghost="select cluster for status")"
    [[ -z "$cluster" ]] && exit 0
  fi

  # Verify cluster exists
  if ! kind get clusters 2>/dev/null | grep -q "^${cluster}\$"; then
    echo -e "${RED} ❌ Cluster '${cluster}' not found${NC}"
    exit 1
  fi

  local config="${KUBECONFIG_DIR}/kind-${cluster}.yaml"

  if [[ ! -f "$config" ]]; then
    echo -e "${RED} ❌ Kubeconfig not found for cluster '${cluster}'${NC}"
    exit 1
  fi

  export KUBECONFIG="$config"

  divider
  echo -e "${GREEN} ☸️  Cluster Status: ${CYAN}${cluster}${NC}\n"

  # Cluster info
  echo -e "${STRONG}Cluster Info:${NC}"
  kubectl cluster-info 2>/dev/null || echo -e "${RED}Failed to get cluster info${NC}"
  echo

  # Nodes
  echo -e "${STRONG}Nodes:${NC}"
  kubectl get nodes -o wide 2>/dev/null || echo -e "${RED}Failed to get nodes${NC}"
  echo

  # System pods
  echo -e "${STRONG}System Pods:${NC}"
  kubectl get pods -A -o wide 2>/dev/null | head -20 || echo -e "${RED}Failed to get pods${NC}"
  echo

  # Services
  echo -e "${STRONG}Services:${NC}"
  kubectl get svc -A 2>/dev/null || echo -e "${RED}Failed to get services${NC}"

  divider
}

delete_cluster() {
  local THIS_CLUSTER="${1}"
  if [[ -z "${THIS_CLUSTER}" ]] || ! kind get clusters 2>/dev/null | grep -q "^${1}\$"; then
    # If no cluster name provided or cluster doesn't exist, prompt with fzf
    local clusters
    clusters="$(kind get clusters 2>/dev/null)"
    if [[ -z "$clusters" ]]; then
      echo -e "${YELLOW} ℹ️  No kind clusters found${NC}"
      exit 0
    fi
    THIS_CLUSTER="$(echo "$clusters" | fzf -1 --layout reverse --border --height 25% --prompt='☸️ ' --ghost="select cluster to delete")"
    [[ -z "$THIS_CLUSTER" ]] && exit 0
  fi

  local KUBECONFIG_YAML="${KUBECONFIG_DIR}/kind-${THIS_CLUSTER}.yaml"

  if [ "${MODE}" == "delete" ]; then
    if [ ! -z "$(kind get clusters)" ]; then
      echo -e "${YELLOW} ⚠️ WARNING: cluster [${THIS_CLUSTER}] will be deleted !!!${NC}"
      if [ "${MODE}" != "dryrun" ] && [[ "${ASSUME_YES}" == "false" ]]; then
        read -rp " 🧨 Proceed [y/N]: " DELETE
        case "${DELETE}" in
        Y | y)
          true
          ;;
        *)
          echo
          exit 0
          ;;
        esac
      fi
      kind delete clusters "${THIS_CLUSTER}" &&
        echo -e " 🔥 ${STRONG}Deleted cluster [${THIS_CLUSTER}]${NC}" &&
        rm -f "${KUBECONFIG_YAML}" &&
        echo -e " 🔥 ${STRONG}Deleted ${KUBECONFIG_YAML}${NC}"
    else
      exit 0
    fi
  fi
}

################################################################################
# parse subcommand + arguments

# Handle version and help flags first (before subcommand)
case "${1:-}" in
-v | --version)
  echo "kindctl v${KINDCTL_VERSION}"
  exit 0
  ;;
-h | --help)
  show_help
  ;;
esac

SUBCOMMAND="${1:-}"
shift 2>/dev/null || true

# parse remaining args
CLUSTER_NAME=""
while [[ $# -gt 0 ]]; do
  case "$1" in
  -d | --dry-run)
    MODE=dryrun
    echo -e "${RED} 🛟 DRY-RUN -- simulating all commands${NC}"
    shift
    ;;
  -y | --yes)
    ASSUME_YES=true
    shift
    ;;
  -h | --help)
    show_help
    ;;
  -v | --version)
    echo "kindctl v${KINDCTL_VERSION}"
    exit 0
    ;;
  -*)
    echo -e "${RED} ❌ Unknown option: $1${NC}"
    show_help
    ;;
  *)
    CLUSTER_NAME="$1"
    shift
    ;;
  esac
done

# main
case "${SUBCOMMAND}" in
new)
  MODE="${MODE:-install}"
  create_cluster "${CLUSTER_NAME}"
  ;;
list)
  list_clusters
  ;;
status)
  status_cluster "${CLUSTER_NAME}"
  ;;
del | delete | rm)
  MODE=delete
  delete_cluster "${CLUSTER_NAME}"
  ;;
*) show_help ;;
esac
